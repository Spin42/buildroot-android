config BR2_PACKAGE_TQFTPSERV
	bool "Qualcomm Trivial QFTP Server (tqftpserv)"
	depends on BR2_PACKAGE_QRTR
	select BR2_PACKAGE_ZSTD
	help
	  TFTP-like server that serves firmware files to Qualcomm remote
	  processors (modem, ADSP, etc.) over the QRTR IPC transport.

	  https://github.com/linux-msm/tqftpserv
